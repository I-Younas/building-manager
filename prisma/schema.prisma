// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  ORG_ADMIN
  STAFF
  RESIDENT
}

enum UnitResidentRelationship {
  OWNER
  TENANT
  FAMILY_MEMBER
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CARD
  ONLINE
  OTHER
}

enum AnnouncementAudience {
  ALL_ORG
  BUILDINGS
  UNITS
  FLOORS
  INDIVIDUALS
}

enum AnnouncementCategory {
  GENERAL
  MAINTENANCE
  EMERGENCY
  POLICY
  EVENT
  BILLING
  AMENITY
}

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum AnnouncementRecurrence {
  NONE
  WEEKLY
  MONTHLY
}

enum RecipientOverrideMode {
  INCLUDE
  EXCLUDE
}

enum AnnouncementDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  FAILED
}

// ---------- Global identity ----------

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  name                  String
  phone                 String?
  dateOfBirth           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  memberships                    OrgMembership[]
  sessions                       Session[]
  passwordResetTokens            PasswordResetToken[]
  unitMemberships                UnitResident[]
  assignedTickets                MaintenanceTicket[]             @relation("AssignedStaff")
  reportedTickets                MaintenanceTicket[]             @relation("ReportedBy")
  ticketComments                 TicketComment[]
  ticketStatusLogs               TicketStatusHistory[]
  issuedInvoices                 Invoice[]                       @relation("IssuedBy")
  recordedPayments               Payment[]                       @relation("RecordedBy")
  postedAnnouncements            Announcement[]                  @relation("PostedBy")
  createdInvites                 InviteCode[]                    @relation("CreatedInvite")
  announcementRecipientOverrides AnnouncementRecipientOverride[]
  announcementAcknowledgments    AnnouncementAcknowledgment[]
  announcementDeliveries         AnnouncementDelivery[]
}

model Session {
  id                   String   @id @default(cuid())
  userId               String
  tokenHash            String   @unique
  activeOrganizationId String?
  expiresAt            DateTime
  createdAt            DateTime @default(now())
  userAgent            String?
  ipAddress            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------- Tenancy ----------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   OrgMembership[]
  buildings     Building[]
  announcements Announcement[]
  inviteCodes   InviteCode[]
}

model OrgMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Building {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  addressLine1   String
  addressLine2   String?
  city           String
  region         String?
  postalCode     String?
  country        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units        Unit[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Unit {
  id             String   @id @default(cuid())
  organizationId String
  buildingId     String
  unitNumber     String
  floor          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  building      Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  residentLinks UnitResident[]
  tickets       MaintenanceTicket[]
  invoices      Invoice[]
  inviteCodes   InviteCode[]

  @@unique([buildingId, unitNumber])
  @@index([organizationId])
}

model UnitResident {
  id           String                    @id @default(cuid())
  unitId       String
  userId       String
  relationship UnitResidentRelationship?
  isPrimary    Boolean                   @default(false)
  createdAt    DateTime                  @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([unitId, userId])
  @@index([userId])
}

// Resident (or staff) onboarding without email delivery.
model InviteCode {
  id             String                    @id @default(cuid())
  organizationId String
  code           String                    @unique
  role           OrgRole
  unitId         String?
  relationship   UnitResidentRelationship?
  email          String?
  createdById    String
  expiresAt      DateTime
  usedAt         DateTime?
  usedByUserId   String?
  createdAt      DateTime                  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CreatedInvite", fields: [createdById], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---------- Module 1: Maintenance & Complaints ----------

model MaintenanceTicket {
  id             String         @id @default(cuid())
  organizationId String
  unitId         String
  reportedById   String
  assignedToId   String?
  title          String
  description    String
  category       String?
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedAt     DateTime?
  resolvedAt     DateTime?

  unit       Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  reportedBy User  @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedTo User? @relation("AssignedStaff", fields: [assignedToId], references: [id])

  comments      TicketComment[]
  statusHistory TicketStatusHistory[]

  @@index([organizationId, status])
  @@index([unitId])
  @@index([assignedToId])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User              @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

model TicketStatusHistory {
  id          String        @id @default(cuid())
  ticketId    String
  changedById String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  note        String?
  createdAt   DateTime      @default(now())

  ticket    MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User              @relation(fields: [changedById], references: [id])

  @@index([ticketId])
}

// ---------- Module 3: Billing & Invoicing ----------

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  unitId         String
  issuedById     String?
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime
  currency       String        @default("USD")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  unit      Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  issuedBy  User?             @relation("IssuedBy", fields: [issuedById], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@index([unitId])
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  amountCents Int
  quantity    Int    @default(1)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  recordedById String
  amountCents  Int
  method       PaymentMethod
  reference    String?
  paidAt       DateTime
  createdAt    DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User    @relation("RecordedBy", fields: [recordedById], references: [id])

  @@index([invoiceId])
}

// ---------- Module 4: Announcement Management ----------

model Announcement {
  id             String    @id @default(cuid())
  organizationId String
  postedById     String
  title          String
  body           String
  publishedAt    DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  audience                   AnnouncementAudience   @default(ALL_ORG)
  targetBuildingIds          String[]               @default([])
  targetUnitIds              String[]               @default([])
  targetFloors               String[]               @default([])
  category                   AnnouncementCategory   @default(GENERAL)
  priority                   AnnouncementPriority   @default(NORMAL)
  status                     AnnouncementStatus     @default(SENT)
  scheduledAt                DateTime?
  recurrence                 AnnouncementRecurrence @default(NONE)
  recurrenceEndsAt           DateTime?
  nextRunAt                  DateTime?
  allowReplies               Boolean                @default(false)
  requireAcknowledgment      Boolean                @default(false)
  acknowledgmentReminderDays Int?
  correctsAnnouncementId     String?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postedBy     User           @relation("PostedBy", fields: [postedById], references: [id])
  corrects     Announcement?  @relation("AnnouncementCorrection", fields: [correctsAnnouncementId], references: [id])
  corrections  Announcement[] @relation("AnnouncementCorrection")

  attachments        AnnouncementAttachment[]
  recipientOverrides AnnouncementRecipientOverride[]
  acknowledgments    AnnouncementAcknowledgment[]
  deliveries         AnnouncementDelivery[]

  @@index([organizationId, publishedAt])
  @@index([organizationId, status])
}

model AnnouncementAttachment {
  id             String   @id @default(cuid())
  announcementId String
  fileName       String
  fileUrl        String
  fileSize       Int
  contentType    String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
}

model AnnouncementRecipientOverride {
  id             String                @id @default(cuid())
  announcementId String
  userId         String
  mode           RecipientOverrideMode
  createdAt      DateTime              @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model AnnouncementAcknowledgment {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  acknowledgedAt DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model AnnouncementDelivery {
  id              String                     @id @default(cuid())
  announcementId  String
  userId          String
  email           String
  resendMessageId String?
  status          AnnouncementDeliveryStatus @default(QUEUED)
  sentAt          DateTime?
  deliveredAt     DateTime?
  bouncedAt       DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([resendMessageId])
}
